[0m05:21:18.988455 [debug] [Thread-4 (]: On model.workshop_demo.int_product_performance: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "workshop_demo", "target_name": "dev", "node_id": "model.workshop_demo.int_product_performance"} */

  
  create view "workshop_demo"."main"."int_product_performance__dbt_tmp" as (
    with products as (
    select * from "workshop_demo"."main"."stg_products"
),
order_items as (
    select
        oi.produto_id as product_id,
        oi.quantidade as quantity,
        oi.preco_unitario_centavos as unit_price_cents,
        o.order_id,
        o.status
    from "workshop_demo"."main"."raw_order_items" oi
    inner join "workshop_demo"."main"."stg_orders" o on oi.pedido_id = o.order_id
    where o.status != 'cancelled'
)
select
    p.product_id,
    p.product_name,
    p.category,
    p.price_cents,
    p.stock,
    count(distinct oi.order_id) as times_ordered,
    coalesce(sum(oi.quantity), 0) as total_units_sold,
    coalesce(sum(oi.quantity * oi.unit_price_cents), 0) as total_revenue_cents,
    
    round(cast(coalesce(sum(oi.quantity * oi.unit_price_cents), 0) as float) / 100, 2)
 as total_revenue_reais
from products p
left join order_items oi on p.product_id = oi.product_id
group by p.product_id, p.product_name, p.category, p.price_cents, p.stock
  );

